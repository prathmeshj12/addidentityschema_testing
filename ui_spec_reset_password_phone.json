{
    "schema": [
      {
        "id": "phone",
        "controlType": "phone",
        "labelName": {
          "en": "Username",
          "km": "ឈ្មោះ​អ្នកប្រើប្រាស់"
        },
        "placeholder": {
          "eng": "Enter username",
          "khm": "បញ្ចូលឈ្មោះ​អ្នកប្រើប្រាស់"
        },
        "validators": [
          {
            "regex": "^\\d{8,9}$",
            "error": {
              "eng": "Username must be a valid phone number with 8 or 9 digits",
              "khm": "ឈ្មោះ​អ្នកប្រើប្រាស់ត្រូវតែជាលេខទូរស័ព្ទដែលមានលេខ 8 ឬ 9 តួ"
            }
          },
          {
            "regex": "^(?!0).*$",
            "error": {
              "eng": "Mobile number should not start with zero",
              "khm": "លេខទូរស័ព្ទមិនគួរចាប់ផ្តើមជាមួយលេខសូន្យ"
            }
          }
        ],
        "required": false,
        "prefix": ["+91", "+855"],
        "alignmentGroup": "groupA",
        "disabled": false
      },
      {
        "id": "qualification",
        "subType": "qualification",
        "controlType": "dropdown",
        "type": "string",
        "capsLockCheck": true,
        "labelName": {
          "eng": "Qualification",
          "khm": "វប្បធម៌"
        },
        "placeholder": {
          "eng": "Select your qualification",
          "khm": "សូមជ្រើសរើសវប្បធម៌"
        },
        "info": {
          "en": "Please select your highest qualification.",
          "khm": "In Khmer, Please select your highest qualification."
        }
      },
      {
        "id": "email",
        "controlType": "textbox",
        "labelName": {
          "eng": "Enter Email Address",
          "khm": "អ៊ីមែល"
        },
        "placeholder": {
          "en": "Enter Email Address",
          "km": "បញ្ចូលអ៊ីមែល"
        },
        "alignmentGroup": "groupB",
        "required": false
      },
      {
        "id": "fullName",
        "controlType": "textbox",
