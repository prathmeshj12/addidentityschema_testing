{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$defs": {
    "langField": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "required": ["language", "value"],
        "additionalProperties": false
      }
    }
  },
  "properties": {
    "individualId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
    },
    "fullName": {
      "allOf": [
        {
          "$ref": "#/$defs/langField"
        },
        {
          "items": {
            "properties": {
              "value": {
                "pattern": "^(?=.*[^\\s])^(?:[a-zA-ZГЂ-Гї\\s]{1,40}|[ШЎ-ЩЉ\\sЩ©Щ±-Ъїп№°-п»їШЂ-Ыї]{1,40}|[бћЂ-бџїб§ -б§їбЁЂ-бЄџ ]{1,40})$"
              },
              "language": {
                "type": "string",
                "enum": ["khm", "eng", "fra", "ara"]
              }
            }
          }
        }
      ]
    },
    "preferredLang": {
      "type": "string",
      "enum": ["khm", "eng", "fra", "ara","hin"],
      "nullable": true
    },
    "phone": {
      "type": "string",
      "pattern": "^\\+91[1-9]\\d{8,9}$"
    },
    "password": {
      "type": "string",
      "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[^A-Za-z\\d]).{8,20}$"
    },
    "email": {
      "type": "string",
      "format": "email"
    }
  },
  "required": ["fullName", "phone", "password","preferredLang","email"],
  "additionalProperties": true
}
